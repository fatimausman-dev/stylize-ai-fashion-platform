{
  "name": "stylize-backend",
  "version": "1.0.0",
  "description": "Stylize backend",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon src/index.ts",
    "build": "tsc && tsc-alias && (cpy .env dist || echo '.env not found, skipping copy')",
    "lint": "eslint src",
    "db:migrate": "npx prisma migrate deploy && npx prisma db push",
    "db:studio": "npx prisma studio",
    "migration:create": "npx prisma migrate dev --create-only",
    "migration:auto": "npx prisma migrate dev",
    "migration:reset": "npx prisma migrate reset",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "Mehmil Mirz",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "axios": "^1.4.0",
    "basic-auth": "^2.0.1",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.0",
    "module-alias": "^2.2.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "nodemailer-smtp-transport": "^2.7.4",
    "npm": "^9.8.1",
    "stripe": "^14.21.0",
    "twilio": "^4.19.3",
    "uuid": "^9.0.0",
    "validator": "^13.9.0",
    "zod": "^3.20.2",
    "zod-validation-error": "^0.3.1"
  },
  "devDependencies": {
    "@types/basic-auth": "^1.1.3",
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.15",
    "@types/http-errors": "^2.0.1",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/module-alias": "^2.0.1",
    "@types/morgan": "^1.9.4",
    "@types/node": "^18.11.18",
    "@types/nodemailer": "^6.4.14",
    "@types/nodemailer-smtp-transport": "^2.7.8",
    "@types/uuid": "^9.0.2",
    "@types/validator": "^13.7.15",
    "@typescript-eslint/eslint-plugin": "^5.48.2",
    "@typescript-eslint/parser": "^5.48.2",
    "cpy-cli": "^5.0.0",
    "eslint": "^8.32.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-import-resolver-typescript": "^3.5.3",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prefer-arrow-functions": "^3.1.4",
    "eslint-plugin-promise": "^6.1.1",
    "husky": "^8.0.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.2",
    "typescript": "^4.9.4"
  }
}
